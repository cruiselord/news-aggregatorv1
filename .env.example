# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# NewsAPI Configuration (server-only)
NEWS_API_KEY=your_newsapi_key_here

# Scraper Configuration
SCRAPER_SECRET=your_secure_scraper_secret_here

# Gemini AI Configuration (optional, uses free tier if not set)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# Groq LLM Configuration (optional, fallback for Gemini)
GROQ_API_KEY=your_groq_api_key_here

# Cron Job Secret (for Vercel)
CRON_SECRET=your_cron_secret_here

# Redis Configuration (optional, for production caching)
REDIS_URL=your_redis_url_here

# Environment
NODE_ENV=development
